export PATH="$HOME/.cargo/bin:$HOME/.local/bin:$PATH"

# Install rustup if missing
if ! command -v rustup &>/dev/null; then
  log_status "installing rustup"
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
fi

# rust-toolchain.toml handles toolchain + components (rustfmt, clippy) automatically.

# Install cargo-nextest (pre-built binary)
if ! command -v cargo-nextest &>/dev/null; then
  log_status "installing cargo-nextest"
  curl -LsSf https://get.nexte.st/latest/linux | install -m 755 /dev/stdin "$HOME/.cargo/bin/cargo-nextest" 2>/dev/null \
    || cargo binstall cargo-nextest --no-confirm 2>/dev/null \
    || cargo install cargo-nextest --locked
fi

# Install prek (pre-built binary)
if ! command -v prek &>/dev/null; then
  log_status "installing prek"
  curl --proto '=https' --tlsv1.2 -LsSf https://github.com/j178/prek/releases/download/v0.3.6/prek-installer.sh | sh
fi

# Install pre-commit hooks via prek
if [ -f .pre-commit-config.yaml ] && command -v prek &>/dev/null; then
  if [ ! -f .git/hooks/pre-commit ]; then
    log_status "installing prek hooks"
    prek install
  fi
fi
