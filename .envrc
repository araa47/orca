#!/usr/bin/env bash
set -e

# Verify Rust toolchain is installed
if ! command -v cargo &>/dev/null; then
    echo "ERROR: Rust toolchain not found. Install via https://rustup.rs/"
    exit 1
fi

# Install prek by default (pre-built binary, fast); then install hooks
if ! command -v prek &>/dev/null; then
    echo "Installing prek..."
    curl --proto '=https' --tlsv1.2 -LsSf https://github.com/j178/prek/releases/download/v0.3.6/prek-installer.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
fi
prek install
